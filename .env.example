# ============================================================
# 数据库连接配置
# ============================================================
#
# 格式：mysql://用户名:密码@主机地址:端口/数据库名
#
# ⚠️ 重要：请根据你的 MySQL 实际情况修改以下内容：
#   - 用户名：root（默认）
#   - 密码：your_password（你的 MySQL 密码）
#   - 主机：localhost（本地开发）
#   - 端口：3306（MySQL 默认端口）
#   - 数据库名：nest_mini（需要先在 MySQL 中手动创建）
#
# 创建数据库命令（在 MySQL 命令行中执行）：
#   CREATE DATABASE nest_mini CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
#
# ⚠️ 注意：
#   - 生产环境请使用真实密码，不要直接写在文件中
#   - 建议通过环境变量注入（如 process.env.DATABASE_URL）
#   - .env 文件不要提交到 Git（已配置在 .gitignore）

DATABASE_URL="mysql://root:your_password@localhost:3306/nest_mini"
